# ConvoLens .gitignore

# Environment and API keys
.env
venv/
env/
*.env

# API keys and secrets
**/api_keys.txt
**/*secret*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data (we'll be selective about what to commit)
data/raw_conversations/*.json
data/raw_conversations/*.csv
# We WILL commit annotated data and samples

# Large files
*.pkl
*.h5
*.hdf5

# Logs
*.log

# Temporary files
temp/
tmp/
*.tmp
